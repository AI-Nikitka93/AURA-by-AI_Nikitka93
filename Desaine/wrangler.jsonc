{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "aura-portfolio-worker",
  "main": "./worker/index.js",
  "compatibility_date": "2026-03-21",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*"
    ],
    "not_found_handling": "single-page-application"
  }
}
